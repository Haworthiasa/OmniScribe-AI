# Copy this file to backend/.env. Never commit real credentials.

# Z.AI GLM-OCR
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/api/paas/v4

# OpenAI-compatible LLM used for metadata enrichment
LLM_API_KEY=
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-4.7-flash

# Absolute path to an Obsidian vault. When empty, demo-vault/ is used.
VAULT_PATH=

# Local development
DEMO_MODE=true
# Safety valve: demo output stays in backend/demo-vault unless explicitly enabled.
DEMO_ALLOW_VAULT_WRITE=false
OCR_CONCURRENCY=2
MAX_UPLOAD_FILES=8
MAX_IMAGE_BYTES=10485760
CORS_ORIGINS=http://localhost:5173
